# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored so secrets never get committed.

PORT=5000

# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# AWS S3 - used to store generated images
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
S3_BUCKET_NAME=your-bucket-name-here

# AWS RDS (PostgreSQL) - stores prompt history and image metadata
DB_HOST=your-db-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ai_image_generator
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Secret key used to sign JWT auth tokens. Generate your own random
# value, e.g. with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_here
